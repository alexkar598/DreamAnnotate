{
  "problemMatcher": [
    {
      "owner": "dreamannotate-dreamchecker",
      "pattern": [
        {
          "regexp": "(.*?), line (\\d+), column (\\d+):",
          "file": 1,
          "line": 2,
          "column": 3
        },
        {
          "regexp": "(error|warning): (.*)",
          "severity": 1,
          "message": 2
        }
      ]
    }
  ]
}